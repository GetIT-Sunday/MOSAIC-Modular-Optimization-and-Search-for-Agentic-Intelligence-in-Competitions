AUTOKAGGLE_API_KEY=YOUR_API_KEY_HERE
AUTOKAGGLE_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Xiaomi MiMo model split.
AUTOKAGGLE_READER_MODEL=mimo-v2.5
AUTOKAGGLE_PLANNER_MODEL=mimo-v2.5-pro
AUTOKAGGLE_DEVELOPER_MODEL=mimo-v2.5
AUTOKAGGLE_REVIEWER_MODEL=mimo-v2.5
AUTOKAGGLE_SUMMARIZER_MODEL=mimo-v2.5

# Use this if Xiaomi does not provide OpenAI-compatible embeddings.
AUTOKAGGLE_DISABLE_TOOL_RAG=1

# Use max_tokens for providers that reject max_completion_tokens.
AUTOKAGGLE_TOKEN_PARAM=max_tokens
